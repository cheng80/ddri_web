// DDRI Minimal MySQL Schema - DBML
// 현재 기준: 선택적 prediction_logs 저장만 지원

Project ddri_db {
  database_type: 'MySQL'
  Note: 'DDRI 모니터링 웹 최소 영속 스키마'
}

Table prediction_logs {
  id bigint [pk, increment]
  prediction_time datetime [not null, note: '예측 실행 시각']
  target_time datetime [not null, note: '예측 대상 시각']
  station_id int [not null, note: '숫자형 대여소 ID']
  horizon_hours int [not null, note: '예측 시간 간격']
  predicted_stock decimal(10,2) [note: '예상 재고']
  predicted_net_change decimal(10,2) [note: '예상 누적 순변화']
  model_version varchar(64)
  source_updated_at datetime [note: '실시간 재고 또는 외부 원천 기준 시각']
  created_at datetime [default: `now()`]

  indexes {
    (station_id, target_time)
    prediction_time
    target_time
    model_version
  }
}
